{
  "name": "imo",
  "version": "1.0.0",
  "description": "A single-page Japanese vocabulary trainer with flashcards, multiple-choice quiz, romaji toggle, search, shuffle, native TTS pronunciation, dark/light mode, keyboard shortcuts, and offline progress saved to `localStorage`.",
  "main": "index.js",
  "scripts": {
    "cap:sync": "cap sync",
    "ios": "cap open ios",
    "android": "cap open android",
    "web": "serve www -l 5173",
    "tts": "python3 tts-server/server.py",
    "dev": "concurrently -k \"serve www -l 5173\" \"npm run tts\"",
    "assets": "capacitor-assets generate --iconBackgroundColor \"#fff7ee\" --splashBackgroundColor \"#fff7ee\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/trueosdev/imo.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/trueosdev/imo/issues"
  },
  "homepage": "https://learnimo.vercel.app",
  "dependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/cli": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.3.1",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "concurrently": "^9.2.1",
    "serve": "^14.2.6"
  }
}
